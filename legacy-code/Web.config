<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <connectionStrings>
    <add name="OrderDB"
         connectionString="Server=SQLPROD01;Database=ContosoOrders;Integrated Security=True;Connection Timeout=30;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <appSettings>
    <!-- Payment Gateway (QuickPay v2) -->
    <add key="PaymentGatewayUrl" value="https://api.quickpay-legacy.com/v2/charge" />
    <add key="MerchantId" value="CONTOSO-2015-PROD" />
    <add key="MerchantSecret" value="sk_live_PLACEHOLDER_ROTATE_ME" />

    <!-- Email Settings -->
    <add key="SmtpHost" value="smtp.contoso.internal" />
    <add key="SmtpPort" value="25" />
    <add key="FromEmail" value="orders@contoso.com" />

    <!-- Feature Flags (added 2019) -->
    <add key="EnableLoyaltyDiscount" value="true" />
    <add key="MaxDiscountAmount" value="50.00" />
  </appSettings>

  <system.web>
    <compilation debug="true" targetFramework="4.5" />
    <httpRuntime targetFramework="4.5" />
  </system.web>

</configuration>
