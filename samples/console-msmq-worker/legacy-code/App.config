<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <add name="OrderDB"
         connectionString="Server=SQLPROD05;Database=ContosoOrders;Integrated Security=True;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>
  <appSettings>
    <add key="MsmqPath" value=".\private$\order-events" />
    <add key="MaxConcurrency" value="1" />
  </appSettings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5" />
  </startup>
</configuration>
