<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <connectionStrings>
    <add name="BillingDB"
         connectionString="Server=SQLPROD02;Database=ContosoBilling;Integrated Security=True;Connection Timeout=30;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>

  <appSettings>
    <add key="SmtpHost" value="smtp.contoso.internal" />
    <add key="BillingApiKey" value="legacy_static_apikey_PLACEHOLDER" />
  </appSettings>

  <system.web>
    <compilation debug="true" targetFramework="4.5" />
    <httpRuntime targetFramework="4.5" />
  </system.web>

  <system.serviceModel>
    <bindings>
      <basicHttpBinding>
        <binding name="BillingBinding" maxReceivedMessageSize="2097152">
          <security mode="None" />
        </binding>
      </basicHttpBinding>
    </bindings>
    <services>
      <service name="Contoso.Billing.BillingService">
        <endpoint address=""
                  binding="basicHttpBinding"
                  bindingConfiguration="BillingBinding"
                  contract="Contoso.Billing.IBillingService" />
        <endpoint address="mex"
                  binding="mexHttpBinding"
                  contract="IMetadataExchange" />
      </service>
    </services>
    <behaviors>
      <serviceBehaviors>
        <behavior>
          <serviceMetadata httpGetEnabled="true" />
          <serviceDebug includeExceptionDetailInFaults="true" />
        </behavior>
      </serviceBehaviors>
    </behaviors>
    <serviceHostingEnvironment aspNetCompatibilityEnabled="true" multipleSiteBindingsEnabled="true" />
  </system.serviceModel>

</configuration>
