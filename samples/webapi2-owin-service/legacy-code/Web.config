<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <add name="OrderDB"
         connectionString="Server=SQLPROD04;Database=ContosoOrders;Integrated Security=True;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>
  <appSettings>
    <add key="DownstreamUrl" value="http://internal-fulfillment.contoso.local/notify" />
    <add key="DownstreamApiKey" value="static_legacy_apikey_PLACEHOLDER" />
  </appSettings>
  <system.web>
    <compilation debug="true" targetFramework="4.6.2" />
    <httpRuntime targetFramework="4.6.2" />
  </system.web>
  <system.webServer>
    <modules>
      <remove name="WebDAVModule" />
    </modules>
  </system.webServer>
</configuration>
