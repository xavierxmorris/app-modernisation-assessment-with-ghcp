<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <add key="InboxPath" value="C:\Inbox\FileProcessor" />
    <add key="ArchivePath" value="C:\Inbox\FileProcessor\archive" />
    <add key="PollSeconds" value="30" />
    <add key="MsmqPath" value=".\private$\fileprocessor" />
  </appSettings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.5" />
  </startup>
</configuration>
